# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost/netflow

# Netflow Collector Configuration
NETFLOW_HOST=0.0.0.0
NETFLOW_PORT=2055
NETFLOW_BATCH_SIZE=1000
NETFLOW_BATCH_TIMEOUT=5.0

# API Configuration
API_MAX_QUERY_LIMIT=1000
API_DEFAULT_LIMIT=100
CORS_ORIGINS=["http://localhost:3000"]

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256

# ML Model Configuration
MODEL_CONTAMINATION=0.1
MODEL_N_ESTIMATORS=100
MODEL_TRAINING_HOURS=24
MODEL_MIN_TRAINING_SAMPLES=100
MODEL_PATH=models/anomaly_detector.pkl
SCALER_PATH=models/scaler.pkl

# Data Retention
DATA_RETENTION_DAYS=5

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Metrics
ENABLE_METRICS=true
METRICS_PORT=9090
